# Copy to .env and fill in as needed. All values are OPTIONAL — the pipeline
# runs fully offline against the bundled datasets without any of these.

# Network egress is OFF by default — patient variant coordinates are never sent
# to gnomAD/NCBI unless you explicitly opt in here. Set to 1 ONLY when you accept
# transmitting individual variant coordinates to those public APIs.
VCF2REPORT_ALLOW_NETWORK=0

# Hard override: OFFLINE=1 forces cache/local-only even if ALLOW_NETWORK=1.
OFFLINE=

# NCBI E-utilities (only used if ALLOW_NETWORK=1): a free key raises the ClinVar
# rate limit from 3 to 10 req/s. https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=
NCBI_EMAIL=you@example.org

# Optional path overrides (defaults point at ./data, ./templates).
# VCF2REPORT_DATA=/abs/path/to/data
# VCF2REPORT_OUT=/abs/path/to/output
